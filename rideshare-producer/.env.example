# Azure Event Hub Configuration
# Copy this file to .env and fill in your values

# Full connection string from Azure Portal > Event Hubs Namespace > Shared Access Policies
EVENTHUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<policy-name>;SharedAccessKey=<key>

# Name of the specific Event Hub (topic) to send events to
EVENTHUB_NAME=rideshare-events

# --- Optional Tuning ---

# How many concurrent trips to maintain at minimum (default: 20)
MIN_CONCURRENT_TRIPS=20

# Interval in seconds between event batches sent to Event Hub (default: 2.5)
SEND_INTERVAL_SECONDS=2.5

# Path for the local JSON backup log file (default: events_backup.jsonl)
BACKUP_LOG_PATH=events_backup.jsonl

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
